# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# PESAPAL_CONSUMER_KEY: Consumer Key for Pesapal Sandbox API
PESAPAL_CONSUMER_KEY="MY_PESAPAL_KEY"

# PESAPAL_CONSUMER_SECRET: Consumer Secret for Pesapal Sandbox API
PESAPAL_CONSUMER_SECRET="MY_PESAPAL_SECRET"

# VITE_ALLOWED_ADMIN_UID: Firebase UID for the system administrator (Vincent Marizon Chelsiah)
VITE_ALLOWED_ADMIN_UID="VINCENT_UID_28_CHARS"
