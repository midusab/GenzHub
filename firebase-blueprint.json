{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "GenZHub user profile and stats",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "dripPostsCount": { "type": "number" },
        "isPremium": { "type": "boolean" },
        "isVerified": { "type": "boolean" },
        "isBanned": { "type": "boolean" },
        "facebookUrl": { "type": "string" },
        "instagramUrl": { "type": "string" },
        "twitterUrl": { "type": "string" },
        "bio": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "displayName", "role"]
    },
    "RadaPost": {
      "title": "Rada News Post",
      "description": "Trending news and gossip for Gen Z",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "source": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "isApproved": { "type": "boolean" },
        "timestamp": { "type": "number" }
      },
      "required": ["title", "content", "timestamp"]
    },
    "DripPost": {
      "title": "Drip Fashion Post",
      "description": "Fashion marketplace listing",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "sold"] },
        "timestamp": { "type": "number" }
      },
      "required": ["title", "price", "sellerId", "timestamp"]
    },
    "HustlePost": {
      "title": "Hustle Gig Post",
      "description": "Gig economy listing",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "type": { "type": "string", "enum": ["gig", "item"] },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "buyerId": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "escrow", "completed"] },
        "timestamp": { "type": "number" }
      },
      "required": ["title", "price", "sellerId", "timestamp"]
    },
    "Transaction": {
      "title": "Payment Transaction",
      "description": "Escrow and premium transaction logs",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["drip_premium", "hustle_escrow", "hustle_fee"] },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "pesapalTrackingId": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["userId", "amount", "status", "timestamp"]
    },
    "Message": {
      "title": "Global Message",
      "description": "Messages in the global chat hub",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderPhoto": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["senderId", "senderName", "text"]
    },
    "ChatRoom": {
      "title": "Private Chat Room",
      "description": "One-on-one or group conversation",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastSenderId": { "type": "string" },
        "lastTimestamp": { "type": "number" },
        "unreadCount": { "type": "object" },
        "updatedAt": { "type": "number" }
      },
      "required": ["participants", "updatedAt"]
    },
    "PrivateMessage": {
      "title": "Private Message",
      "description": "Message within a private chat room",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "number" },
        "type": { "type": "string", "enum": ["text", "image", "system"] }
      },
      "required": ["senderId", "text", "timestamp"]
    },
    "Notification": {
      "title": "App Notification",
      "description": "User notifications",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "isRead": { "type": "boolean" },
        "timestamp": { "type": "number" }
      },
      "required": ["userId", "title", "message", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "posts_rada/{postId}": {
      "schema": "RadaPost",
      "description": "News feed items"
    },
    "posts_drip/{postId}": {
      "schema": "DripPost",
      "description": "Fashion marketplace items"
    },
    "posts_hustle/{postId}": {
      "schema": "HustlePost",
      "description": "Gig economy listings"
    },
    "transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial transaction logs"
    },
    "global_messages/{msgId}": {
      "schema": "Message",
      "description": "Global chat messages"
    },
    "chats/{chatId}": {
      "schema": "ChatRoom",
      "description": "Active private conversations"
    },
    "chats/{chatId}/messages/{msgId}": {
      "schema": "PrivateMessage",
      "description": "Messages within a specific chat"
    },
    "notifications/{notifId}": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
